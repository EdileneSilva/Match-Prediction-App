# Variables d'environnement (copie ce fichier en `.env` avant de lancer)

# --- Bases de données ---
# API Application (auth, historique, favoris)
DATABASE_APP_URL=postgresql://postgres:postgres@localhost:5432/footballapp_db
# Note: FastAPI_App utilise aussi DATABASE_URL par défaut, on harmonisera dans le code.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/footballapp_db

# API ML (matchs, entraînement, prédiction)
DATABASE_ML_URL=postgresql://postgres:postgres@localhost:5432/footballprediction_db

# --- URLs des Services ---
ML_API_URL=http://localhost:8001
APP_API_URL=http://localhost:8000

# --- Chemins ML (relatifs à FastAPI_ML/) ---
MODEL_PATH=../Data/dataset/match_model_v1.joblib
DATASET_PATH=../Data/dataset/completed_match_dataset_final.csv
DATA_DIR=../Data

# --- Auth JWT (API Application) ---
SECRET_KEY=change-me-to-a-very-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

